{
  "name": "flashcards",
  "version": "3.2.0",
  "description": "Spaced-repetition app and CLI for durable, agent-assisted flashcard decks",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "flashcards": "./bin/flashcards.js"
  },
  "files": [
    ".agents/skills/manage-flashcard-decks/",
    "bin/",
    "scripts/add-card-ids.js",
    "scripts/validate-notes.js",
    "src/card-id-annotator.js",
    "src/hasher.js",
    "src/parser.js",
    "templates/",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently \"vite\" \"node scripts/watch-simple.js\"",
    "dev:no-watch": "vite",
    "build": "vite build && node scripts/build.js",
    "preview": "vite preview",
    "process-submodules": "node scripts/build.js",
    "add-card-ids": "node scripts/add-card-ids.js",
    "watch": "node scripts/watch-simple.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@noble/hashes": "^1.3.3",
    "commander": "^14.0.2",
    "dompurify": "^3.3.3",
    "katex": "^0.16.9",
    "marked": "^11.1.1",
    "ts-fsrs": "^4.1.0"
  },
  "devDependencies": {
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.1",
    "vite": "^5.0.11",
    "vitest": "^1.6.1"
  }
}
